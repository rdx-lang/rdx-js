{
  "name": "@rdx-lang/wasm",
  "version": "0.1.0",
  "description": "RDX parser, validator, and transforms — compiled to WebAssembly",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build:wasm": "wasm-pack build ../../rdx/rdx-wasm --target web --out-dir ../../rdx-js/packages/wasm/wasm-pkg",
    "build": "bun run build:wasm && bun build ./src/index.ts --outdir dist --target browser && bun x tsc --emitDeclarationOnly"
  },
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/rdx-lang/rdx-js",
    "directory": "packages/wasm"
  },
  "dependencies": {
    "@rdx-lang/types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8"
  }
}
